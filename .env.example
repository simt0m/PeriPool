# Copy this file to .env and fill in real values for local development.
# .env is gitignored and must never be committed.

# Selects which config class to load: development | testing | production
FLASK_CONFIG=development

# Secret key used to sign sessions and CSRF tokens.
# A development-only fallback is used automatically if this is left blank,
# but it is required (the app refuses to start without it) when
# FLASK_CONFIG=production.
SECRET_KEY=
